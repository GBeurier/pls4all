/* pls4all visibility macros — generated by CMake from n4m_export.h.in.
 *
 * N4M_API:   default-visibility / dllexport when building libn4m,
 *            dllimport when consuming libn4m from another shared library,
 *            empty on static / archive builds.
 * N4M_LOCAL: hidden visibility for internal symbols that may end up in
 *            extern "C" sections.
 *
 * The C/C++ public header `pls4all/p4a.h` includes this file before declaring
 * any function. Users of pls4all never include this header directly. */
#ifndef PLS4ALL_P4A_EXPORT_H
#define PLS4ALL_P4A_EXPORT_H

#if defined(_WIN32) || defined(__CYGWIN__)
#  ifdef PLS4ALL_BUILDING_DLL
#    ifdef __GNUC__
#      define N4M_API __attribute__((dllexport))
#    else
#      define N4M_API __declspec(dllexport)
#    endif
#  elif defined(PLS4ALL_STATIC)
#    define N4M_API
#  else
#    ifdef __GNUC__
#      define N4M_API __attribute__((dllimport))
#    else
#      define N4M_API __declspec(dllimport)
#    endif
#  endif
#  define N4M_LOCAL
#else
#  if __GNUC__ >= 4
#    define N4M_API   __attribute__((visibility("default")))
#    define N4M_LOCAL __attribute__((visibility("hidden")))
#  else
#    define N4M_API
#    define N4M_LOCAL
#  endif
#endif

#endif /* PLS4ALL_P4A_EXPORT_H */
