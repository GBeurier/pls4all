/* pls4all visibility macros — generated by CMake from p4a_export.h.in.
 *
 * P4A_API:   default-visibility / dllexport when building libp4a,
 *            dllimport when consuming libp4a from another shared library,
 *            empty on static / archive builds.
 * P4A_LOCAL: hidden visibility for internal symbols that may end up in
 *            extern "C" sections.
 *
 * The C/C++ public header `pls4all/p4a.h` includes this file before declaring
 * any function. Users of pls4all never include this header directly. */
#ifndef PLS4ALL_P4A_EXPORT_H
#define PLS4ALL_P4A_EXPORT_H

#if defined(_WIN32) || defined(__CYGWIN__)
#  ifdef PLS4ALL_BUILDING_DLL
#    ifdef __GNUC__
#      define P4A_API __attribute__((dllexport))
#    else
#      define P4A_API __declspec(dllexport)
#    endif
#  elif defined(PLS4ALL_STATIC)
#    define P4A_API
#  else
#    ifdef __GNUC__
#      define P4A_API __attribute__((dllimport))
#    else
#      define P4A_API __declspec(dllimport)
#    endif
#  endif
#  define P4A_LOCAL
#else
#  if __GNUC__ >= 4
#    define P4A_API   __attribute__((visibility("default")))
#    define P4A_LOCAL __attribute__((visibility("hidden")))
#  else
#    define P4A_API
#    define P4A_LOCAL
#  endif
#endif

#endif /* PLS4ALL_P4A_EXPORT_H */
