/* nirs4all-methods visibility macros — generated by CMake from n4m_export.h.in.
 *
 * N4M_API:   default-visibility / dllexport when building libn4m,
 *            dllimport when consuming libn4m from another shared library,
 *            empty on static / archive builds.
 * N4M_LOCAL: hidden visibility for internal symbols that may end up in
 *            extern "C" sections.
 *
 * The C/C++ public header `n4m/n4m.h` includes this file before declaring
 * any function. Users of nirs4all-methods never include this header directly. */
#ifndef N4M_N4M_EXPORT_H
#define N4M_N4M_EXPORT_H

#if defined(_WIN32) || defined(__CYGWIN__)
#  if defined(N4M_BUILDING_DLL) || defined(N4M_BUILDING_C_DLL)
#    ifdef __GNUC__
#      define N4M_API __attribute__((dllexport))
#    else
#      define N4M_API __declspec(dllexport)
#    endif
#  elif defined(N4M_STATIC)
#    define N4M_API
#  else
#    ifdef __GNUC__
#      define N4M_API __attribute__((dllimport))
#    else
#      define N4M_API __declspec(dllimport)
#    endif
#  endif
#  define N4M_LOCAL
#else
#  if __GNUC__ >= 4
#    define N4M_API   __attribute__((visibility("default")))
#    define N4M_LOCAL __attribute__((visibility("hidden")))
#  else
#    define N4M_API
#    define N4M_LOCAL
#  endif
#endif

#endif /* N4M_N4M_EXPORT_H */
