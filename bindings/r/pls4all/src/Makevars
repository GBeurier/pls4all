# Compile / link flags for the pls4all R package.
#
# Override the locator env vars to point at your checkout of pls4all:
#
#   PLS4ALL_INCLUDE_DIR=$REPO/cpp/include \
#   PLS4ALL_GENERATED_DIR=$REPO/build/<preset>/generated \
#   PLS4ALL_LIB_DIR=$REPO/build/<preset>/cpp/src \
#     R CMD INSTALL --no-staged-install bindings/r/pls4all
#
# PLS4ALL_GENERATED_DIR is the directory containing the
# `pls4all/p4a_export.h` file generated by CMake at configure time.
#
# At runtime, libp4a must be findable via LD_LIBRARY_PATH (Linux),
# DYLD_LIBRARY_PATH (macOS) or PATH (Windows MSVC/MinGW).

PLS4ALL_INCLUDE_DIR ?=
PLS4ALL_GENERATED_DIR ?=
PLS4ALL_LIB_DIR ?=

ifeq ($(strip $(PLS4ALL_INCLUDE_DIR)),)
PKG_CPPFLAGS = -I$(R_PACKAGE_DIR)/../../cpp/include
else
PKG_CPPFLAGS = -I$(PLS4ALL_INCLUDE_DIR)
endif

ifneq ($(strip $(PLS4ALL_GENERATED_DIR)),)
PKG_CPPFLAGS += -I$(PLS4ALL_GENERATED_DIR)
endif

ifeq ($(strip $(PLS4ALL_LIB_DIR)),)
PKG_LIBS = -lp4a
else
PKG_LIBS = -L$(PLS4ALL_LIB_DIR) -Wl,-rpath,$(PLS4ALL_LIB_DIR) -lp4a
endif
