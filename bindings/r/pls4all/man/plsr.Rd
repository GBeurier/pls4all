% Generated by hand; keep in sync with R/pls_compat.R
\name{plsr}
\alias{plsr}
\alias{pcr}
\alias{mvr}
\alias{predict.pls4all_mvr}
\alias{coef.pls4all_mvr}
\alias{MSEP}
\alias{RMSEP}
\alias{R2}
\alias{selectNcomp}
\title{PLS package compatibility facade}
\usage{
plsr(
  formula,
  ncomp = 2L,
  data,
  subset,
  na.action = stats::na.omit,
  method = c("kernelpls", "widekernelpls", "simpls",
             "oscorespls", "cppls", "nipals"),
  scale = FALSE,
  validation = c("none", "CV"),
  segments = 10L,
  center = TRUE,
  fit_components = TRUE,
  gamma = 0.5,
  sparsity_lambda = 0,
  ...
)

pcr(
  formula,
  ncomp = 2L,
  data,
  subset,
  na.action = stats::na.omit,
  method = c("svdpc", "pcr"),
  scale = FALSE,
  validation = c("none", "CV"),
  segments = 10L,
  center = TRUE,
  fit_components = TRUE,
  ...
)

mvr(
  formula,
  ncomp = 2L,
  data,
  subset,
  na.action = stats::na.omit,
  method = c("kernelpls", "widekernelpls", "simpls",
             "oscorespls", "cppls", "nipals", "pcr"),
  scale = FALSE,
  validation = c("none", "CV"),
  segments = 10L,
  center = TRUE,
  model = c("plsr", "pcr"),
  fit_components = TRUE,
  gamma = 0.5,
  sparsity_lambda = 0,
  ...
)

MSEP(object, ...)

RMSEP(object, ...)

R2(object, ...)

selectNcomp(object, method = c("min"), estimate = c("CV", "train"), ...)
}
\arguments{
\item{formula}{A two-sided model formula.}
\item{ncomp}{Number of latent components.}
\item{data}{Data frame containing formula variables.}
\item{subset}{Optional row subset.}
\item{na.action}{Missing-value action.}
\item{method}{PLS/PCR algorithm selector.}
\item{scale}{Logical; standardize predictors and response.}
\item{validation}{\code{"none"} or \code{"CV"}.}
\item{segments}{Number of contiguous CV segments, or a list of assessment row indices.}
\item{center}{Logical; center predictors and response.}
\item{fit_components}{Logical; fit component prefixes 1:ncomp for component-wise prediction and metrics.}
\item{gamma}{CPPLS gamma.}
\item{sparsity_lambda}{Sparse-SIMPLS soft threshold for the dense SIMPLS-compatible path.}
\item{model}{\code{"plsr"} or \code{"pcr"}.}
\item{object}{A \code{pls4all_mvr} object.}
\item{estimate}{Metric source, \code{"train"} or \code{"CV"}.}
\item{...}{Reserved for compatibility.}
}
\value{
\code{plsr()}, \code{pcr()} and \code{mvr()} return a
\code{pls4all_mvr} object. \code{MSEP()}, \code{RMSEP()} and
\code{R2()} return a small \code{mvrVal}-compatible list with a
\code{val} array. \code{selectNcomp()} returns an integer component
count.
}
\description{
These functions provide the familiar formula-oriented surface of the
R \pkg{pls} package without importing it. Computation is backed by
\pkg{pls4all}; the facade is intended for NIRS/chemometrics scripts
that already use \code{plsr()}, \code{pcr()}, \code{predict()},
\code{RMSEP()} and \code{selectNcomp()} patterns.
}
\examples{
\dontrun{
set.seed(1)
df <- data.frame(x1 = rnorm(40), x2 = rnorm(40))
df$y <- 2 * df$x1 - df$x2 + rnorm(40, sd = 0.05)
fit <- plsr(y ~ ., data = df, ncomp = 2, method = "simpls")
predict(fit, df, ncomp = 1:2)
RMSEP(fit)
selectNcomp(fit)
}
}
