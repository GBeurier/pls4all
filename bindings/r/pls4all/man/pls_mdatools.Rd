% Generated by hand; keep in sync with R/mdatools_compat.R
\name{pls_mdatools}
\alias{pls_mdatools}
\alias{predict.n4m_mdatools_pls}
\title{mdatools-style matrix PLS interface}
\usage{
pls_mdatools(
  x,
  y,
  ncomp = min(nrow(x) - 1L, ncol(x), 20L),
  center = TRUE,
  scale = FALSE,
  cv = NULL,
  exclcols = NULL,
  exclrows = NULL,
  x.test = NULL,
  y.test = NULL,
  method = c("simpls", "cppls", "kernelpls",
             "widekernelpls", "oscorespls", "nipals", "pcr"),
  info = "",
  ncomp.selcrit = "min",
  lim.type = "ddmoments",
  alpha = 0.05,
  gamma = 0.5,
  cv.scope = "local",
  prep = NULL,
  fit_components = TRUE,
  ...
)
}
\arguments{
\item{x}{Numeric predictor matrix.}
\item{y}{Numeric response vector or matrix.}
\item{ncomp}{Maximum number of components.}
\item{center}{Logical; center predictors and response.}
\item{scale}{Logical; standardize predictors and response.}
\item{cv}{\code{NULL}, an integer number of folds, or a list of assessment row indices.}
\item{exclcols}{Optional predictor columns to exclude.}
\item{exclrows}{Optional rows to exclude before fitting.}
\item{x.test}{Optional external test predictor matrix.}
\item{y.test}{Optional external test response vector or matrix.}
\item{method}{PLS/PCR algorithm selector.}
\item{info}{Free-form model label.}
\item{ncomp.selcrit}{Stored for compatibility.}
\item{lim.type}{Stored for compatibility.}
\item{alpha}{Stored for compatibility.}
\item{gamma}{CPPLS gamma when \code{method = "cppls"}.}
\item{cv.scope}{Stored for compatibility.}
\item{prep}{Optional preprocessing function applied to \code{x} and \code{x.test}.}
\item{fit_components}{Logical; fit component prefixes 1:ncomp.}
\item{...}{Reserved for compatibility.}
}
\value{
A \code{n4m_mdatools_pls} object with calibration results in
\code{calres}; optional cross-validation and test results are stored in
\code{cvres} and \code{testres}.
}
\description{
Matrix-oriented PLS facade modelled after \code{mdatools::pls(x, y, ...)}
for NIRS/chemometrics workflows. The top-level \code{pls(x, y, ...)}
function dispatches here when its first argument is not a formula.
}
\examples{
\dontrun{
set.seed(1)
X <- matrix(rnorm(80), 20, 4)
y <- X[, 1] - X[, 2] + rnorm(20, sd = 0.05)
fit <- pls_mdatools(X, y, ncomp = 3, cv = 5)
predict(fit, x = X)
fit$calres$rmse
fit$cvres$rmse
}
}
