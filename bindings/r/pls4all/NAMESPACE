useDynLib(pls4all, .registration = TRUE)

importFrom(stats, model.frame, model.matrix, model.response, na.omit,
           na.pass, terms, delete.response, .getXlevels)

export(pls4all_version)
export(pls4all_abi_version)
export(pls4all_fit)
export(pls4all_predict)

# Tier 1 — MethodResult fits
export(sparse_simpls_fit)
export(cppls_fit)
export(weighted_pls_fit)
export(mb_pls_fit)
export(pls_glm_fit)
export(mir_pls_fit)

# Tier 1 — selectors
export(vip_select)
export(coefficient_select)
export(selectivity_ratio_select)
export(spa_select)
export(cars_select)

# Tier 1 — diagnostics
export(pls_diagnostics)
export(approximate_press)
export(pls_monitoring)

# Tier 2 — base R formula interface (idiomatic style)
export(pls)
S3method(predict, pls4all_fit)
S3method(coef, pls4all_fit)
S3method(print, pls4all_fit)
S3method(summary, pls4all_fit)
S3method(print, summary.pls4all_fit)

# Tier 2 — formula-based wrappers around MethodResult fits
export(sparse_pls)
export(cppls)
export(weighted_pls)
export(mb_pls)
export(pls_glm)
export(mir_pls)
S3method(predict, pls4all_method_fit)
S3method(coef, pls4all_method_fit)
S3method(print, pls4all_method_fit)
S3method(summary, pls4all_method_fit)
S3method(print, summary.pls4all_method_fit)

# Tier 2 — tidymodels / parsnip engine (lazy registration)
export(register_parsnip)
export(pls_pls4all_reg)

# Tier 2 — mlr3 / R6 learner (lazy registration)
export(register_mlr3)
