# Default: text files use LF, autodetect binary.
*           text=auto eol=lf

# Forcibly text (LF) — sources and configs.
*.c         text eol=lf
*.h         text eol=lf
*.cpp       text eol=lf
*.cxx       text eol=lf
*.cc        text eol=lf
*.hpp       text eol=lf
*.hxx       text eol=lf
*.cmake     text eol=lf
CMakeLists.txt text eol=lf
*.in        text eol=lf
*.md        text eol=lf
*.py        text eol=lf
*.R         text eol=lf
*.r         text eol=lf
*.m         text eol=lf
*.ts        text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.cff       text eol=lf

# Windows tooling — keep CRLF if the file is generated on / for Windows.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary — never normalise.
*.png       binary
*.jpg       binary
*.gif       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.so        binary
*.dylib     binary
*.dll       binary
*.wasm      binary
*.bin       binary
*.npy       binary
*.parquet   binary
*.joblib    binary

# Export-ignore (kept in git, excluded from `git archive` tarballs).
.github/        export-ignore
.gitattributes  export-ignore
.gitignore      export-ignore
.editorconfig   export-ignore
.clang-format   export-ignore
.clang-tidy     export-ignore
.mcp.json       export-ignore
docs/reviews/   export-ignore
