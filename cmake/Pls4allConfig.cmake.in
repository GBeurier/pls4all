@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# pls4all has no mandatory dependencies. Optional accelerated backends are
# detected at runtime via n4m_context_set_backend(); CMake consumers never
# need to find anything else to use libn4m.

include("${CMAKE_CURRENT_LIST_DIR}/Pls4allTargets.cmake")

check_required_components(pls4all)

set(PLS4ALL_VERSION       @PROJECT_VERSION@)
set(PLS4ALL_VERSION_MAJOR @PROJECT_VERSION_MAJOR@)
set(PLS4ALL_VERSION_MINOR @PROJECT_VERSION_MINOR@)
set(PLS4ALL_VERSION_PATCH @PROJECT_VERSION_PATCH@)
