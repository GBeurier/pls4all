@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# nirs4all-methods has no mandatory dependencies. Optional accelerated backends are
# detected at runtime via n4m_context_set_backend(); CMake consumers never
# need to find anything else to use libn4m.

include("${CMAKE_CURRENT_LIST_DIR}/N4MTargets.cmake")

check_required_components(N4M)

set(N4M_VERSION       @PROJECT_VERSION@)
set(N4M_VERSION_MAJOR @PROJECT_VERSION_MAJOR@)
set(N4M_VERSION_MINOR @PROJECT_VERSION_MINOR@)
set(N4M_VERSION_PATCH @PROJECT_VERSION_PATCH@)
