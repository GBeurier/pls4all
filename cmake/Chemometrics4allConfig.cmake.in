@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# chemometrics4all has no mandatory dependencies. Optional accelerated backends are
# detected at runtime via c4a_context_set_backend(); CMake consumers never
# need to find anything else to use libc4a.

include("${CMAKE_CURRENT_LIST_DIR}/Chemometrics4allTargets.cmake")

check_required_components(chemometrics4all)

set(CHEMOMETRICS4ALL_VERSION       @PROJECT_VERSION@)
set(CHEMOMETRICS4ALL_VERSION_MAJOR @PROJECT_VERSION_MAJOR@)
set(CHEMOMETRICS4ALL_VERSION_MINOR @PROJECT_VERSION_MINOR@)
set(CHEMOMETRICS4ALL_VERSION_PATCH @PROJECT_VERSION_PATCH@)
